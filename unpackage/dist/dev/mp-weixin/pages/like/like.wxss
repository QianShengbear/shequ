/* 文章场景相关 */
.container.data-v-03e14ebf {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部按钮 */
.header.data-v-03e14ebf {
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

/* 列表容器 */
.list-container.data-v-03e14ebf {
  height: calc(100vh - 120rpx);
}

/* 空状态提示 */
.empty-tip.data-v-03e14ebf {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}
.empty-tip text.data-v-03e14ebf {
  margin-top: 20rpx;
}

/* 用户列表项 */
.user-item.data-v-03e14ebf {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #fff;
  margin-bottom: 2rpx;
  position: relative;
}
.user-item.data-v-03e14ebf:active {
  background-color: #f8f8f8;
}
.user-item .user-info-area.data-v-03e14ebf {
  flex: 1;
  display: flex;
  align-items: center;
}
.user-item .user-info.data-v-03e14ebf {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}
.user-item .user-info .nickname.data-v-03e14ebf {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}
.user-item .user-info .bio.data-v-03e14ebf {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}
.user-item .unfollow-btn.data-v-03e14ebf {
  padding: 10rpx;
  margin-left: 10rpx;
}
.user-item .unfollow-btn.data-v-03e14ebf:active {
  opacity: 0.6;
}

/* 弹窗内容 */
.popup-content.data-v-03e14ebf {
  width: 600rpx;
  max-height: 800rpx;
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}
.popup-header.data-v-03e14ebf {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}
.popup-header .title.data-v-03e14ebf {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.search-box.data-v-03e14ebf {
  padding: 20rpx;
}
.search-result.data-v-03e14ebf {
  max-height: 500rpx;
}
.no-result.data-v-03e14ebf {
  display: flex;
  justify-content: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
.result-item.data-v-03e14ebf {
  display: flex;
  align-items: center;
  padding: 5rpx;
  border-bottom: 1rpx solid #f5f5f5;
  /* 用户头像 - 向左对齐 */
  /* 用户名和简介容器 - 垂直布局，占据中间空间 */
  /* 关注图标 - 向右对齐 */
}
.result-item .u-avatar.data-v-03e14ebf {
  flex-shrink: 0;
}
.result-item .result-info.data-v-03e14ebf {
  flex: 1;
  min-width: 0;
  /* 允许收缩 */
  margin-left: 20rpx;
  margin-right: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  /* 用户名样式 */
  /* 简介样式 - 与用户名间隔5px */
}
.result-item .result-info .nickname.data-v-03e14ebf {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.result-item .result-info .bio.data-v-03e14ebf {
  font-size: 24rpx;
  color: #999;
  margin-top: 5px;
}
.result-item .follow-icon.data-v-03e14ebf,
.result-item .followed-icon.data-v-03e14ebf {
  flex-shrink: 0;
  margin-left: auto;
  padding: 10rpx;
}
.result-item .follow-icon.data-v-03e14ebf:active,
.result-item .followed-icon.data-v-03e14ebf:active {
  opacity: 0.6;
}
.result-item .follow-icon.data-v-03e14ebf {
  cursor: pointer;
}
.result-item .followed-icon.data-v-03e14ebf {
  cursor: default;
}