/* 文章场景相关 */
.container.data-v-1cf27b2a {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部按钮 */
.header.data-v-1cf27b2a {
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 10;
}

/* 帖子列表 */
.post-list.data-v-1cf27b2a {
  height: calc(100vh - 120rpx);
}

/* 空状态提示 */
.empty-tip.data-v-1cf27b2a {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}
.empty-tip text.data-v-1cf27b2a {
  margin-top: 20rpx;
}

/* 帖子项 */
.post-item.data-v-1cf27b2a {
  background-color: #fff;
  margin-bottom: 2rpx;
  padding: 20rpx;
}
.post-item .post-header.data-v-1cf27b2a {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
  /* 关注图标样式 */
}
.post-item .post-header .user-info.data-v-1cf27b2a {
  flex: 1;
  margin-left: 15rpx;
  display: flex;
  flex-direction: column;
}
.post-item .post-header .user-info .nickname.data-v-1cf27b2a {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}
.post-item .post-header .user-info .time.data-v-1cf27b2a {
  font-size: 22rpx;
  color: #999;
  margin-top: 5rpx;
}
.post-item .post-header .follow-icon.data-v-1cf27b2a,
.post-item .post-header .followed-icon.data-v-1cf27b2a {
  flex-shrink: 0;
  margin-left: 10rpx;
  padding: 8rpx;
}
.post-item .post-header .follow-icon.data-v-1cf27b2a:active,
.post-item .post-header .followed-icon.data-v-1cf27b2a:active {
  opacity: 0.6;
}
.post-item .post-header .follow-icon.data-v-1cf27b2a {
  cursor: pointer;
}
.post-item .post-header .followed-icon.data-v-1cf27b2a {
  cursor: default;
}
.post-item .post-content.data-v-1cf27b2a {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 15rpx;
  word-wrap: break-word;
}
.post-item .post-actions.data-v-1cf27b2a {
  display: flex;
  align-items: center;
  padding-top: 15rpx;
  border-top: 1rpx solid #f5f5f5;
}
.post-item .post-actions .action-item.data-v-1cf27b2a {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
  color: #999;
  font-size: 24rpx;
  cursor: pointer;
}
.post-item .post-actions .action-item text.data-v-1cf27b2a {
  margin-left: 8rpx;
}

/* 发布弹窗 */
.publish-popup.data-v-1cf27b2a {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx 20rpx 0 0;
}
.popup-header.data-v-1cf27b2a {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.popup-header .cancel-btn.data-v-1cf27b2a {
  font-size: 28rpx;
  color: #999;
}
.popup-header .title.data-v-1cf27b2a {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}
.post-textarea.data-v-1cf27b2a {
  width: 100%;
  min-height: 300rpx;
  font-size: 28rpx;
  color: #333;
  padding: 15rpx;
  background-color: #f8f8f8;
  border-radius: 10rpx;
  box-sizing: border-box;
}
.char-count.data-v-1cf27b2a {
  text-align: right;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #999;
}