/* 文章场景相关 */
.container.data-v-2f1ef635 {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

/* 头像区域 */
.avatar-section.data-v-2f1ef635 {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  background-color: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}
.avatar-section .avatar.data-v-2f1ef635 {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #2867CE;
  margin-bottom: 20rpx;
}
.avatar-section .avatar-tip.data-v-2f1ef635 {
  font-size: 24rpx;
  color: #999;
}

/* 表单区域 */
.form-section.data-v-2f1ef635 {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 40rpx;
}
.form-section .form-item.data-v-2f1ef635 {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}
.form-section .form-item.data-v-2f1ef635:last-child {
  border-bottom: none;
}
.form-section .form-item .label.data-v-2f1ef635 {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: bold;
}
.form-section .form-item .input.data-v-2f1ef635 {
  width: 100%;
  height: 70rpx;
  line-height: 70rpx;
  font-size: 28rpx;
  color: #333;
  padding: 0 20rpx;
  background-color: #f8f8f8;
  border-radius: 10rpx;
}
.form-section .form-item .textarea.data-v-2f1ef635 {
  width: 100%;
  min-height: 150rpx;
  font-size: 28rpx;
  color: #333;
  padding: 15rpx 20rpx;
  background-color: #f8f8f8;
  border-radius: 10rpx;
  box-sizing: border-box;
}
.form-section .form-item .gender-item.data-v-2f1ef635 {
  display: inline-flex;
  align-items: center;
  margin-right: 40rpx;
  font-size: 28rpx;
  color: #333;
}
.form-section .form-item .gender-item radio.data-v-2f1ef635 {
  margin-right: 10rpx;
}

/* 保存按钮 */
.save-btn.data-v-2f1ef635 {
  width: 90%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #2867CE;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  margin: 0 auto;
  display: block;
}
.save-btn.data-v-2f1ef635:active {
  background-color: #1e52a8;
}