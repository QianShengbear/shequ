/* 文章场景相关 */
.container.data-v-0a633310 {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部用户信息 */
.chat-header.data-v-0a633310 {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}
.chat-header .nickname.data-v-0a633310 {
  flex: 1;
  margin-left: 15rpx;
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

/* 消息内容区域容器 */
.messages-container.data-v-0a633310 {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background-color: #f5f5f5;
}

/* 消息列表滚动区域 */
.message-list.data-v-0a633310 {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}
.empty-tip.data-v-0a633310 {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100%;
  color: #999;
  font-size: 28rpx;
}
.message-item.data-v-0a633310 {
  margin-bottom: 30rpx;
}
.message-item .time-wrapper.data-v-0a633310 {
  display: flex;
  justify-content: center;
  margin: 10rpx 0;
}
.message-item .message-row.data-v-0a633310 {
  display: flex;
  align-items: flex-end;
  width: 100%;
  margin: 10rpx;
  justify-content: flex-start;
}
.message-item .message-row.my-row.data-v-0a633310 {
  justify-content: flex-end;
}
.message-item .message-bubble.data-v-0a633310 {
  max-width: 70%;
  padding: 15rpx 20rpx;
  border-radius: 15rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-wrap: break-word;
  margin: 0 25rpx 5rpx 25rpx;
}
.message-item .message-bubble.other-bubble.data-v-0a633310 {
  background-color: #fff;
  color: #333;
  border: 1rpx solid #e0e0e0;
}
.message-item .message-bubble.my-bubble.data-v-0a633310 {
  background-color: #2867CE;
  color: #fff;
}
.message-item .message-time.data-v-0a633310 {
  display: inline-block;
  font-size: 22rpx;
  color: #999;
  background-color: #dcdcdc;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

/* 底部输入区域 */
.input-area.data-v-0a633310 {
  display: flex;
  align-items: center;
  padding: 15rpx 20rpx;
  background-color: #fff;
  border-top: 1rpx solid #eee;
  min-height: 200rpx;
}

/* 图片选择按钮 */
.image-btn.data-v-0a633310 {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  margin-right: 10rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
}
.image-btn.data-v-0a633310:active {
  background-color: #e8e8e8;
}

/* 输入框 - 优化高度和样式 */
.message-input.data-v-0a633310 {
  flex: 1;
  min-height: 30px;
  max-height: 150px;
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 15rpx;
  font-size: 28rpx;
  line-height: 1.5;
  margin-right: 15rpx;
  box-sizing: border-box;
  color: #333;
  border: 1rpx solid #e0e0e0;
}

/* 发送按钮容器 */
.send-btn-wrapper.data-v-0a633310 {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}